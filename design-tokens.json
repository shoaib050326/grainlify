{
  "version": "1.0.0",
  "description": "Grainlify Design Tokens - Cohesive visual language for dashboard and marketing surfaces",
  "rationale": {
    "accessibility": "WCAG 2.1 AA compliant - 4.5:1 contrast for text, 3:1 for UI components. All color combinations tested.",
    "steller_alignment": "Warm neutral palette inspired by Stellar ecosystem credibility - professional, trustworthy, avoiding generic AI aesthetics. Gold accent for premium feel without excess.",
    "consistency": "Unified tokens across frontend (React/Tailwind) and website (Docusaurus) for seamless brand experience.",
    "dark_mode": "Full dark mode support with proper contrast ratios maintained."
  },
  "color": {
    "primary": {
      "50": "#fef7e6",
      "100": "#fdf0cc",
      "200": "#fae199",
      "300": "#f7d266",
      "400": "#f4c333",
      "500": "#f1b400",
      "600": "#c9983a",
      "700": "#a67c2e",
      "800": "#8b6527",
      "900": "#6c4e1f",
      "950": "#3a2710"
    },
    "neutral": {
      "50": "#fafaf9",
      "100": "#f5f5f4",
      "200": "#e7e5e4",
      "300": "#d6d3d1",
      "400": "#a8a29e",
      "500": "#78716c",
      "600": "#57534e",
      "700": "#44403c",
      "800": "#292524",
      "900": "#1c1917",
      "950": "#0c0a09"
    },
    "semantic": {
      "success": {
        "50": "#f0fdf4",
        "500": "#22c55e",
        "600": "#16a34a",
        "700": "#15803d"
      },
      "warning": {
        "50": "#fffbeb",
        "500": "#f59e0b",
        "600": "#d97706",
        "700": "#b45309"
      },
      "error": {
        "50": "#fef2f2",
        "500": "#ef4444",
        "600": "#dc2626",
        "700": "#b91c1c"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": ["Inter", "system-ui", "-apple-system", "sans-serif"],
      "mono": ["JetBrains Mono", "monospace"]
    },
    "fontSize": {
      "xs": ["0.75rem", { "lineHeight": "1rem" }],
      "sm": ["0.875rem", { "lineHeight": "1.25rem" }],
      "base": ["1rem", { "lineHeight": "1.5rem" }],
      "lg": ["1.125rem", { "lineHeight": "1.75rem" }],
      "xl": ["1.25rem", { "lineHeight": "1.75rem" }],
      "2xl": ["1.5rem", { "lineHeight": "2rem" }],
      "3xl": ["1.875rem", { "lineHeight": "2.25rem" }],
      "4xl": ["2.25rem", { "lineHeight": "2.5rem" }],
      "5xl": ["3rem", { "lineHeight": "1" }],
      "6xl": ["3.75rem", { "lineHeight": "1" }]
    },
    "fontWeight": {
      "thin": "100",
      "extralight": "200",
      "light": "300",
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700",
      "extrabold": "800",
      "black": "900"
    }
  },
  "spacing": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem",
    "32": "8rem",
    "40": "10rem",
    "48": "12rem",
    "56": "14rem",
    "64": "16rem"
  },
  "borderRadius": {
    "none": "0",
    "sm": "0.125rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "3xl": "1.5rem",
    "full": "9999px"
  },
  "elevation": {
    "shadow": {
      "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
      "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
      "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
      "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
      "2xl": "0 25px 50px -12px rgb(0 0 0 / 0.25)"
    },
    "glass": {
      "backdrop": "blur(12px)",
      "border": "1px solid rgba(255 255 255 / 0.2)"
    }
  },
  "animation": {
    "duration": {
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms"
    },
    "easing": {
      "ease": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-in": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-out": "cubic-bezier(0, 0, 0.2, 1)",
      "ease-in-out": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  }
}